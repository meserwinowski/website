<!-- Base layout: wraps all pages with head, header, content area, and footer -->
---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import { ClientRouter } from 'astro:transitions';

// Props interface: defines what data this component expects from its parent.
interface Props {
  title: string;
  description?: string;
  // Container width: 'prose' = readable measure, 'content' = project-detail content rail,
  // 'wide' = centered reading column with a Table of Contents gutter (project detail pages).
  width?: 'prose' | 'content' | 'wide';
  // Header alignment: 'project-detail' aligns chrome to the same rail as project detail content.
  chrome?: 'prose' | 'project-detail';
  // Show the top scroll-progress bar. Defaults to true; opt out on pages that don't want it.
  readingProgress?: boolean;
}

// Destructure props with a default description for SEO
const { title, description = 'Matt Serwinowski — software engineer, builder of things.', width = 'prose', chrome = 'prose', readingProgress = true } = Astro.props;

// Resolve the page container width to a CSS var, exposed to header/main/footer as --container
const contentRailWidth = 'calc(var(--width-prose) + ((var(--width-wide) - var(--width-prose)) / 4.236) + 14rem)';
// Project detail pages center the prose column and place the Table of Contents in
// the right gutter. The container fits a symmetric rail — prose plus a matching
// gutter (ToC width + gap) on each side — so the reading column lands dead-center.
const projectRailWidth = 'calc(var(--width-prose) + (2 * (14rem + 2rem)))';
const containerWidths: Record<NonNullable<Props['width']>, string> = {
  prose: 'var(--width-prose)',
  content: contentRailWidth,
  wide: projectRailWidth,
};
const containerWidth = containerWidths[width];
const chromeContainerWidth = chrome === 'project-detail'
  ? contentRailWidth
  : 'var(--width-prose)';

// Build the full URL for this page (used in Open Graph tags)
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!-- DOCTYPE tells the browser this is a modern HTML5 document -->
<!doctype html>
<!-- lang="en" helps screen readers and search engines know this is English -->
<!-- data-theme="dark" sets the default color scheme (our CSS reads this attribute) -->
<html lang="en" data-theme="dark">
  <!-- <head> contains metadata — not visible on the page itself -->
  <head>
    <!-- charset: tells the browser what character encoding to use (UTF-8 = all languages) -->
    <meta charset="UTF-8" />
    <!-- color-scheme tells browsers and extensions (like Dark Reader) this site handles its own dark mode -->
    <meta name="color-scheme" content="dark light" />

    <!-- Inline script runs BEFORE the page paints — prevents a "flash" of wrong theme -->
    <!-- is:inline tells Astro to leave this script as-is (not bundle it) -->
    <!-- Also re-applies theme after View Transitions swap to prevent reset -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
      document.addEventListener('astro:after-swap', function() {
        var theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      });
    </script>

    <!-- viewport: makes the page responsive on mobile (scales to device width) -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- description: shown in search engine results under the page title -->
    <meta name="description" content={description} />
    <!-- canonical URL: tells search engines the "official" URL for this page -->
    <link rel="canonical" href={canonicalURL.href} />
    <!-- favicon: the small icon shown in the browser tab -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph: controls how the page looks when shared on social media -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Matt Serwinowski" />

    <!-- Twitter card: controls how the page looks when shared on X/Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Preconnect: opens a connection to Google Fonts early so fonts load faster -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Load Inter (body text) and JetBrains Mono (code/header) from Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

    <!-- {title} is a dynamic value — Astro replaces it with the prop passed to this layout -->
    <title>{title}</title>

    <!-- ClientRouter enables View Transitions: smooth crossfade animations between pages -->
    <!-- Instead of full page reloads, the browser morphs one page into the next -->
    <!-- This eliminates the "flash" on navigation and makes the site feel like an app -->
    <ClientRouter />
  </head>

  <!-- flex + min-h-screen + flex-col makes footer stick to the bottom even on short pages -->
  <!-- --container drives the <main> width (set per page via the width prop). Header/footer -->
  <!-- stay pinned to --width-prose so the site chrome is identical on every page. -->
  <body class="flex min-h-screen flex-col" style={`--container: ${containerWidth}; --chrome-container: ${chromeContainerWidth};`}>
    <!-- Top scroll-progress bar: fills as the reader moves down long pages. -->
    {readingProgress && <ReadingProgress />}
    <!-- Header component: nav bar with logo, links, theme toggle -->
    <Header />

    <!-- <main> stays full-width and is the shared View Transition object, so the animated -->
    <!-- box is the SAME size on every page — transitions are identical pure slides. -->
    <!-- The inner wrapper carries the per-page width cap (--container), centering, and padding. -->
    <!-- transition:name="main" gives this element a unique identity for the View Transitions API -->
    <main class="w-full flex-1" transition:name="main">
      <div class="mx-auto w-full max-w-[var(--container,var(--width-prose))] px-6 pt-6 pb-12">
        <!-- <slot /> is where child content gets injected.
             When a page does <Layout><h1>Hello</h1></Layout>,
             the <h1>Hello</h1> appears here -->
        <slot />
      </div>
    </main>

    <!-- Footer component: copyright bar -->
    <Footer />

    <!-- Floating scroll helper: appears after scrolling down on longer pages -->
    <BackToTop />

    <!-- Directional navigation script: determines slide direction before each transition -->
    <!-- This runs client-side and sets a data-transition attribute that CSS reads -->
    <script>
      // Nav link order — used to determine "left vs right" for same-depth navigation
      const NAV_ORDER: Record<string, number> = {
        '/': 0,
        '/projects': 1,
        '/posts': 2,    // Keep position reserved for when posts are enabled
        '/about': 3,
      };

      // How many segments deep a path is (e.g., "/" = 0, "/projects" = 1, "/projects/foo" = 2)
      function getDepth(path: string): number {
        return path.replace(/\/$/, '').split('/').filter(Boolean).length;
      }

      // Get the nav index for a path (falls back to its parent if it's a detail page)
      function getNavIndex(path: string): number {
        const clean = path.replace(/\/$/, '') || '/';
        if (clean in NAV_ORDER) return NAV_ORDER[clean];
        // For nested pages like /projects/mech-keyboard, use parent's index
        const parent = '/' + clean.split('/').filter(Boolean)[0];
        return NAV_ORDER[parent] ?? 0;
      }

      function setNavigationDirection(event: any) {
        const from = event.from.pathname;
        const to = event.to.pathname;

        const fromDepth = getDepth(from);
        const toDepth = getDepth(to);

        let direction: string;

        if (toDepth > fromDepth) {
          // Going deeper (e.g., /projects → /projects/keyboard): slide right
          direction = 'slide-right';
        } else if (toDepth < fromDepth) {
          // Going shallower (e.g., /projects/keyboard → /projects): slide left
          direction = 'slide-left';
        } else {
          // Same depth — use nav order (Home=0, Projects=1, Posts=2, About=3)
          const fromIndex = getNavIndex(from);
          const toIndex = getNavIndex(to);
          direction = toIndex >= fromIndex ? 'slide-right' : 'slide-left';
        }

        document.documentElement.setAttribute('data-transition', direction);
      }

      // Before each navigation, figure out direction and set the CSS attribute.
      // Astro re-executes inline scripts across view-transition swaps, so bind once.
      const navigationWindow = window as Window & { __directionalNavigationBound?: boolean };
      if (!navigationWindow.__directionalNavigationBound) {
        document.addEventListener('astro:before-preparation', setNavigationDirection);
        navigationWindow.__directionalNavigationBound = true;
      }
    </script>
  </body>
</html>
