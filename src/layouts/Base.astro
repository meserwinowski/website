---
/**
 * Base.astro — The site shell shared by every page.
 *
 * Layout components are Astro's page wrappers: pages pass metadata and content
 * into this component, then `<slot />` below decides where that page content is
 * inserted. The frontmatter section runs at build/render time for imports,
 * prop defaults, SEO URLs, and layout-width calculations; the template section
 * is the HTML that becomes the static page.
 */

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import CollapsibleDetails from '../components/CollapsibleDetails.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  /** Full browser/tab title. Home uses just the name; other pages append the site name. */
  title: string;
  /** Meta/Open Graph description; defaults to the site's short bio. */
  description?: string;
  /**
   * Main content rail:
   * - `prose` keeps text at a comfortable reading measure.
   * - `content` widens the rail for bespoke pages like About.
   * - `wide` reserves balanced gutters for project detail pages.
   */
  width?: 'prose' | 'content' | 'wide';
  /** Header/footer chrome alignment; project detail pages use their content rail. */
  chrome?: 'prose' | 'project-detail';
  /** Whether to render the top scroll-progress bar. */
  readingProgress?: boolean;
  /** Optional CSS width/calc override for pages that need a custom gutter. */
  containerWidth?: string;
}

// Destructure props from the parent page and apply layout-wide defaults.
const { title, description = 'Matt Serwinowski — software engineer, builder of things.', width = 'prose', chrome = 'prose', readingProgress = true, containerWidth: containerWidthOverride } = Astro.props;

// Resolve page width to CSS variables. The actual tokens live in global.css so
// layout math stays centralized in the design system.
const contentRailWidth = 'calc(var(--width-prose) + ((var(--width-wide) - var(--width-prose)) / 4.236) + 14rem)';
// Project detail pages center the prose column and place the Table of Contents in
// the right gutter. The container fits a symmetric rail — prose plus a matching
// gutter (ToC width + gap) on each side — so the reading column lands dead-center.
const projectRailWidth = 'calc(var(--width-prose) + (2 * (14rem + 2rem)))';
const containerWidths: Record<NonNullable<Props['width']>, string> = {
  prose: 'var(--width-prose)',
  content: contentRailWidth,
  wide: projectRailWidth,
};
const containerWidth = containerWidthOverride ?? containerWidths[width];
const chromeContainerWidth = chrome === 'project-detail'
  ? contentRailWidth
  : 'var(--width-prose)';
// containerWidth/chromeContainerWidth are injected onto <body> as the
// --container / --chrome-container CSS variables so Tailwind arbitrary values
// (e.g. max-w-[var(--container)]) can consume these design-system widths.

// Build the canonical absolute URL for SEO and social-sharing metadata.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
{/* Default to dark in markup; the inline pre-paint script below applies saved preference. */}
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    {/* Advertise both schemes because theme colors are handled by CSS custom properties. */}
    <meta name="color-scheme" content="dark light" />

    {/* is:inline keeps this tiny script in the document head so it runs before first paint. */}
    <script is:inline>
      // Apply the saved theme before CSS paints to avoid a flash of wrong theme (FOUC).
      (function() {
        var theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
      // Astro View Transitions swap document fragments; re-apply the attribute after swaps.
      document.addEventListener('astro:after-swap', function() {
        var theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      });
    </script>

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph and Twitter metadata keep shared links consistent across platforms. */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Matt Serwinowski" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {/* Preconnect warms up Google Fonts before requesting Inter and JetBrains Mono. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    {/* ClientRouter enables Astro View Transitions for app-like page navigation. */}
    <ClientRouter />
  </head>

  <body class="flex min-h-screen flex-col" style={`--container: ${containerWidth}; --chrome-container: ${chromeContainerWidth};`}>
    {/* Optional reading progress is useful for long-form content but can be disabled. */}
    {readingProgress && <ReadingProgress />}
    <Header />

    {/* Keep <main> full-width as the shared View Transition object; constrain inside it. */}
    <main class="w-full flex-1" transition:name="main">
      <div class="mx-auto w-full max-w-[var(--container,var(--width-prose))] px-6 pt-6 pb-12">
        {/* <slot /> is where the page using this layout injects its own content. */}
        <slot />
      </div>
    </main>

    <Footer />

    <BackToTop />

    <CollapsibleDetails />

    {/* Client script sets a direction flag that transition CSS reads before navigation. */}
    <script>
      // Nav link order — used to determine "left vs right" for same-depth navigation
      const NAV_ORDER: Record<string, number> = {
        '/': 0,
        '/projects': 1,
        '/posts': 2,    // Keep position reserved for when posts are enabled
        '/about': 3,
      };

      // How many segments deep a path is (e.g., "/" = 0, "/projects" = 1, "/projects/foo" = 2)
      function getDepth(path: string): number {
        return path.replace(/\/$/, '').split('/').filter(Boolean).length;
      }

      // Get the nav index for a path (falls back to its parent if it's a detail page)
      function getNavIndex(path: string): number {
        const clean = path.replace(/\/$/, '') || '/';
        if (clean in NAV_ORDER) return NAV_ORDER[clean];
        // For nested pages like /projects/mech-keyboard, use parent's index
        const parent = '/' + clean.split('/').filter(Boolean)[0];
        return NAV_ORDER[parent] ?? 0;
      }

      function setNavigationDirection(event: any) {
        const from = event.from.pathname;
        const to = event.to.pathname;

        const fromDepth = getDepth(from);
        const toDepth = getDepth(to);

        let direction: string;

        if (toDepth > fromDepth) {
          // Going deeper (e.g., /projects → /projects/keyboard): slide right
          direction = 'slide-right';
        } else if (toDepth < fromDepth) {
          // Going shallower (e.g., /projects/keyboard → /projects): slide left
          direction = 'slide-left';
        } else {
          // Same depth — use nav order (Home=0, Projects=1, Posts=2, About=3)
          const fromIndex = getNavIndex(from);
          const toIndex = getNavIndex(to);
          direction = toIndex >= fromIndex ? 'slide-right' : 'slide-left';
        }

        document.documentElement.setAttribute('data-transition', direction);
      }

      // Before each navigation, figure out direction and set the CSS attribute.
      // Astro re-executes inline scripts across view-transition swaps, so bind once.
      const navigationWindow = window as Window & { __directionalNavigationBound?: boolean };
      if (!navigationWindow.__directionalNavigationBound) {
        document.addEventListener('astro:before-preparation', setNavigationDirection);
        navigationWindow.__directionalNavigationBound = true;
      }
    </script>
  </body>
</html>
