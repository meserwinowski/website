---
/**
 * TableOfContents.astro — Section jump links for rendered Markdown pages.
 * Uses Astro's heading metadata so links match the generated Markdown heading IDs.
 */
interface Heading {
  // Markdown heading depth: 1 for h1, 2 for h2, etc.
  depth: number;
  // The id Astro generated for the heading; used as the scroll target.
  slug: string;
  // Plain text label shown in the ToC.
  text: string;
}

interface Props {
  // Pre-filtered heading metadata from src/pages/projects/[slug].astro.
  headings: Heading[];
  // Desktop renders as a sticky side nav; mobile renders as a collapsible block.
  variant?: 'desktop' | 'mobile';
}

const { headings, variant = 'desktop' }: Props = Astro.props;

// Visual hierarchy for heading levels. Deeper sections are indented, and each
// level gets its own color (blue → muted white → muted gray) so readers can
// tell heading depths apart at a glance. Colors are theme-aware tokens (global.css).
const depthClasses: Record<number, string> = {
  1: 'pl-0 font-semibold text-[var(--color-toc-1)]',
  2: 'pl-4 text-[var(--color-toc-2)]',
  3: 'pl-8 text-[var(--color-toc-3)]',
};

// Buttons look like text links but avoid native hash navigation. That lets the
// custom scroll handler fully control the movement without browser/router jumps.
// appearance-none is required so iOS Safari doesn't override our text color with
// its native button chrome (the ToC links would otherwise lose their color on mobile).
// The accent hover color is applied via a scoped @media (hover: hover) rule below
// so it doesn't stick after a tap on touch devices.
const linkBaseClasses = 'toc-link block w-full cursor-pointer appearance-none rounded bg-transparent py-0.5 text-left text-sm leading-tight';
const titleClasses = 'font-mono text-sm font-semibold leading-5 text-[var(--color-accent)]';
const title = 'On This Page';
---

{headings.length > 1 && (
  variant === 'mobile' ? (
    <details class="toc-mobile rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 lg:hidden">
      <!-- Mobile ToC: collapsed by default so it does not take over the top of the page. -->
      <summary class:list={['flex cursor-pointer items-center justify-between gap-2', titleClasses]}>
        <span>{title}</span>
        <svg class="toc-chevron h-[1.35rem] w-[1.35rem] shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </summary>
      <nav aria-label="Table of contents" class="mt-4">
        <ol class="border-l border-[var(--color-border)] pl-4">
          {headings.map((heading) => (
            <li>
              <!-- data-toc-target stores the heading id for the click handler below. -->
              <button
                type="button"
                data-toc-target={heading.slug}
                class:list={[linkBaseClasses, depthClasses[heading.depth] ?? depthClasses[3]]}
              >
                {heading.text}
              </button>
            </li>
          ))}
        </ol>
      </nav>
    </details>
  ) : (
    <nav aria-label="Table of contents" class="hidden lg:block">
      <!-- Desktop ToC: hidden below lg; the project layout places it in the right rail. -->
      <p class:list={['mb-2', titleClasses]}>
        {title}
      </p>
      <ol class="border-l border-[var(--color-border)] pl-4">
        {headings.map((heading) => (
          <li>
            <!-- Buttons keep the URL hash/browser router from interrupting smooth scroll. -->
            <button
              type="button"
              data-toc-target={heading.slug}
              class:list={[linkBaseClasses, depthClasses[heading.depth] ?? depthClasses[3]]}
            >
              {heading.text}
            </button>
          </li>
        ))}
      </ol>
    </nav>
  )
)}

<script>
  // Slightly slower than native smooth scrolling so long project pages feel deliberate.
  const scrollDurationMs = 900;
  // Incremented for each new click so repeated clicks cancel older animations.
  let activeAnimationFrame = 0;

  // Same easing curve as BackToTop: gentle start/end, faster middle.
  function easeInOutCubic(progress: number) {
    return progress < 0.5
      ? 4 * progress * progress * progress
      : 1 - Math.pow(-2 * progress + 2, 3) / 2;
  }

  // Respect the CSS scroll-margin-top set on prose headings so the target
  // heading lands with a little breathing room instead of flush to the viewport.
  function getScrollMarginTop(target: HTMLElement) {
    const margin = Number.parseFloat(window.getComputedStyle(target).scrollMarginTop);
    return Number.isNaN(margin) ? 0 : margin;
  }

  function animateScrollTo(targetY: number) {
    // Snapshot start and distance so the animation always moves from the user's
    // current position to the target, regardless of direction.
    const startY = window.scrollY;
    const distance = targetY - startY;
    const startTime = performance.now();
    const animationFrame = activeAnimationFrame + 1;
    activeAnimationFrame = animationFrame;

    function step(now: number) {
      // A newer click cancels this animation loop.
      if (animationFrame !== activeAnimationFrame) {
        return;
      }

      const elapsed = now - startTime;
      const progress = Math.min(elapsed / scrollDurationMs, 1);

      window.scrollTo(0, startY + distance * easeInOutCubic(progress));

      if (progress < 1) {
        window.requestAnimationFrame(step);
      }
    }

    window.requestAnimationFrame(step);
  }

  // Delegated handler for both mobile and desktop ToC buttons.
  function handleTableOfContentsClick(event: MouseEvent) {
    // Let modified clicks behave normally if the browser ever receives them.
    if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
      return;
    }

    const button = (event.target as Element | null)?.closest<HTMLButtonElement>('[data-toc-target]');
    const targetId = button?.dataset.tocTarget;

    if (!button || !targetId) {
      return;
    }

    const target = document.getElementById(targetId);

    if (!target) {
      return;
    }

    // Prevent native click/routing behavior so there is no instant jump or snap-back.
    event.preventDefault();
    event.stopImmediatePropagation();

    const targetY = target.getBoundingClientRect().top + window.scrollY - getScrollMarginTop(target);
    animateScrollTo(targetY);
  }

  // Astro view transitions can re-run scripts. Store a window-level flag so the
  // global delegated listener is installed only once.
  const tocWindow = window as Window & { __tableOfContentsScrollBound?: boolean };

  if (!tocWindow.__tableOfContentsScrollBound) {
    document.addEventListener('click', handleTableOfContentsClick, { capture: true });
    tocWindow.__tableOfContentsScrollBound = true;
  }
</script>

<style>
  /* Replace the native disclosure triangle with our own right-aligned chevron
     that points right when collapsed and rotates down when expanded. */
  .toc-mobile > summary {
    list-style: none;
  }
  .toc-mobile > summary::-webkit-details-marker {
    display: none;
  }
  .toc-chevron {
    transition: transform 0.2s ease;
  }
  .toc-mobile[open] > summary .toc-chevron {
    transform: rotate(90deg);
  }
  /* Only apply the hover accent on devices with a real pointer. On touch the
     :hover state would otherwise stick after a tap until you tap elsewhere. */
  @media (hover: hover) {
    .toc-link:hover {
      color: var(--color-accent);
    }
  }
</style>
