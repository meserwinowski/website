---
/**
 * ProjectCard.astro — A clickable card that previews a project.
 *
 * Used on the /projects index page, one card per generated project. Astro
 * frontmatter defines the prop contract and build-time formatting; the template
 * turns that data into one large accessible link so the whole card is tappable.
 */

interface Props {
  /** URL-friendly project ID, used to build `/projects/{slug}/`. */
  slug: string;
  /** Display title shown in the card and thumbnail fallback. */
  title: string;
  /** Short summary copied from project frontmatter. */
  description: string;
  /** Project lifecycle state; the union keeps badges limited to known values. */
  status: 'done' | 'ongoing' | 'planning' | 'idea';
  /** Category labels rendered as small design-token badges. */
  tags: string[];
  /** Optional preview image path; missing images fall back to a text tile. */
  thumbnail?: string | null;
  /** Project date, used for the semantic <time> element. */
  date: Date;
}

// Astro.props contains the attributes passed by the parent page/component.
const { slug, title, description, status, tags, thumbnail, date } = Astro.props;

// Human-readable date (e.g. "Jun 7, 2026") plus a machine-readable ISO value for <time datetime>.
// Format in UTC so the displayed day matches the frontmatter date regardless of the build machine's timezone.
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
const dateISO = date.toISOString().split('T')[0];

// Status badge styling. These semantic colors mirror ProjectMeta so cards and
// detail pages speak the same visual language.
const statusColors: Record<string, string> = {
  'done': 'bg-green-500/20 text-green-400',
  'ongoing': 'bg-blue-500/20 text-blue-400',
  'planning': 'bg-yellow-500/20 text-yellow-400',
  'idea': 'bg-purple-500/20 text-purple-400',
};

// Human-readable labels keep content data terse while the UI reads naturally.
const statusLabels: Record<string, string> = {
  'done': 'Done',
  'ongoing': 'Ongoing',
  'planning': 'Planning',
  'idea': 'Idea',
};
---

{/* A single anchor makes the whole card reachable by mouse, touch, and keyboard. */}
<a href={`/projects/${slug}/`} class="group block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden hover:border-[var(--color-accent)] no-underline">

  {/* Fixed 16:9 media area keeps the grid stable even with mixed thumbnail sizes. */}
  <div class="aspect-video overflow-hidden">
    {/* Prefer a real thumbnail; fall back to a text tile so every card has media. */}
    {thumbnail ? (
      <img
        src={thumbnail}
        alt={`${title} thumbnail`}
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-[var(--color-surface)] border-b border-[var(--color-border)]">
        <span class="px-4 text-center font-mono text-sm text-[var(--color-muted)]">{title}</span>
      </div>
    )}
  </div>

  {/* Card body uses design-system color tokens so it adapts to light/dark themes. */}
  <div class="p-4 space-y-2">

    <div class="flex items-center justify-between gap-2">
      {/* Dynamic class picks the badge color from the frontmatter status. */}
      <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${statusColors[status]}`}>
        {statusLabels[status]}
      </span>
      {/* <time> keeps the date understandable to parsers while remaining readable. */}
      <time datetime={dateISO} class="text-xs text-[var(--color-muted)]">{formattedDate}</time>
    </div>

    <h3 class="text-lg font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
      {title}
    </h3>

    {/* Clamp long descriptions so every card keeps a comparable height. */}
    <p class="text-sm text-[var(--color-muted)] line-clamp-2">{description}</p>

    <div class="flex flex-wrap gap-1 pt-1">
      {/* Astro templates can use JavaScript expressions like map() to repeat markup. */}
      {tags.map((tag) => (
        <span class="text-xs px-2 py-0.5 rounded bg-[var(--color-bg)] text-[var(--color-muted)]">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
