---
/**
 * Footer.astro — Site-wide copyright and build metadata.
 *
 * Astro frontmatter (this `---` block) runs on the server at build time, not in
 * the browser. That makes it a good place to stamp the static site with the
 * year and build date that should be baked into every generated page.
 */

// Current year for the copyright line. This is evaluated once per build.
const year = new Date().getFullYear();

// Build timestamp: when this static site was generated. Format the visible text
// in UTC so it agrees with the UTC-based `datetime` attribute below regardless
// of the machine or CI runner timezone.
const buildDate = new Date();
const formattedBuildDate = buildDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
const buildDateISO = buildDate.toISOString().split('T')[0];
---

{/* Semantic footer landmark shared by every page via Base.astro. */}
<footer class="border-t border-[var(--color-border)] py-8">
  {/* Theme-aware color tokens come from global.css and work in both light/dark themes. */}
  <div class="mx-auto max-w-[var(--width-prose)] px-6 text-center text-sm text-[var(--color-muted)]">
    <p>&copy; {year} Matt Serwinowski</p>
    {/* <time> gives machines an ISO date while humans get a friendly label. */}
    <p class="mt-1 text-xs">Last updated <time datetime={buildDateISO}>{formattedBuildDate}</time></p>
  </div>
</footer>
