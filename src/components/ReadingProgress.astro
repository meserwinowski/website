---
/**
 * ReadingProgress.astro — A thin scroll-progress bar pinned to the top of the viewport.
 *
 * Rendered site-wide from Base.astro, but it stays hidden on short pages where a
 * progress indicator would add noise. The browser-side math is the standard
 * scroll ratio: current scroll offset divided by total scrollable distance
 * (`scrollTop / (scrollHeight - clientHeight)`). This implementation uses the
 * equivalent root-page values available on `window`/`documentElement`.
 *
 * The element is `aria-hidden` because it is purely visual; screen-reader users
 * already have landmarks/headings for orientation.
 */
---

{/* Decorative progress meter; the script below owns its transform and opacity. */}
<div id="reading-progress" class="reading-progress" aria-hidden="true"></div>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 60;
    height: 3px;
    width: 100%;
    /* Scaled from 0→1 on scroll; origin-left so it grows from the left edge. */
    transform: scaleX(0);
    transform-origin: left;
    background: var(--color-accent);
    opacity: 0;
    pointer-events: none;
    /* Only fade the visibility; the width tracks scroll instantly for a tight feel. */
    transition: opacity 0.2s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress {
      /* Honor reduced-motion preferences by removing even the small opacity fade. */
      transition: none;
    }
  }
</style>

<script>
  // Pages shorter than this (in px of scrollable distance) don't show the bar —
  // it only earns its place on genuinely long, scrollable reading pages.
  const minScrollablePx = 240;

  /**
   * Recompute and paint the progress bar for the current page geometry.
   *
   * `scrollHeight - innerHeight` is the distance the root page can actually
   * scroll. The ratio is clamped to 0→1 so bounce/overscroll and browser rounding
   * cannot create invalid `scaleX()` values.
   */
  function updateReadingProgress() {
    const bar = document.getElementById('reading-progress');

    if (!bar) {
      return;
    }

    const doc = document.documentElement;
    const scrollable = doc.scrollHeight - window.innerHeight;

    if (scrollable <= minScrollablePx) {
      bar.style.opacity = '0';
      bar.style.transform = 'scaleX(0)';
      return;
    }

    const progress = Math.min(Math.max(window.scrollY / scrollable, 0), 1);
    bar.style.transform = `scaleX(${progress})`;
    // Fade in only once the reader has actually started moving.
    bar.style.opacity = progress > 0.005 ? '1' : '0';
  }

  // Astro re-runs component scripts across view transitions; guard the global
  // listeners so they bind only once for the page lifetime.
  const progressWindow = window as Window & { __readingProgressBound?: boolean };

  if (!progressWindow.__readingProgressBound) {
    // Passive listeners promise not to call preventDefault, letting browsers keep scrolling smooth.
    window.addEventListener('scroll', updateReadingProgress, { passive: true });
    // Resize changes `scrollHeight - innerHeight`, so the ratio must be recalculated.
    window.addEventListener('resize', updateReadingProgress, { passive: true });
    // Astro fires this after View Transition navigations, when the document height may change.
    document.addEventListener('astro:page-load', updateReadingProgress);
    progressWindow.__readingProgressBound = true;
  }

  // Initial paint covers direct page loads before any scroll/resize event fires.
  updateReadingProgress();
</script>
