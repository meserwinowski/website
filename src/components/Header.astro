---
/**
 * Header.astro — Site-wide navigation, social links, theme toggle, and mobile drawer.
 *
 * Astro frontmatter runs at build/render time, so it is used here for static
 * navigation data and current-path calculations. The template below emits the
 * semantic landmarks, while the browser <script> at the bottom handles the
 * interactive mobile menu after the page loads.
 */

import SocialLinks from './SocialLinks.astro';
import ThemeToggle from './ThemeToggle.astro';

// Single source of truth for site navigation. Both desktop and mobile menus
// loop over this array, so adding a page here updates both experiences.
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  // { href: '/posts', label: 'Posts' },  // Uncomment when posts content is ready
  { href: '/about/', label: 'About' },
];

// Normalize trailing slashes so `/projects` and `/projects/` highlight the same
// nav item. Astro.url is available in component frontmatter during rendering.
const currentPath = Astro.url.pathname;
const normalizedCurrentPath = currentPath === '/' ? '/' : `${currentPath.replace(/\/$/, '')}/`;
---

{/* Semantic header landmark shared by every page through Base.astro. */}
<header class="border-b border-[var(--color-border)]">
  {/* --chrome-container lets Base.astro align global chrome with each page's rail. */}
  <nav class="mx-auto flex max-w-[var(--chrome-container,var(--width-prose))] items-center justify-between px-6 py-4">

    <div class="flex items-center gap-4">
      {/* Short mono wordmark doubles as the home link. */}
      <a href="/" class="font-mono text-2xl font-semibold text-[var(--color-text)] no-underline hover:text-[var(--color-accent)]">
        MS
      </a>
      <SocialLinks />
      <ThemeToggle />
    </div>

    {/* Desktop nav is hidden below Tailwind's sm breakpoint; the drawer handles mobile. */}
    <ul class="hidden gap-6 sm:flex">
      {navLinks.map(({ href, label }) => (
        <li>
          {/* class:list is Astro's built-in helper for conditional class names. */}
          <a
            href={href}
            class:list={[
              'inline-block text-xl no-underline',
              normalizedCurrentPath === href
                ? 'text-[var(--color-accent)]'
                : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    {/* aria-controls/expanded connect this icon button to the drawer for screen readers. */}
    <button
      id="mobile-nav-toggle"
      class="relative z-50 rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] p-1.5 text-[var(--color-muted)] hover:border-[var(--color-muted)] hover:text-[var(--color-text)] sm:hidden"
      aria-label="Toggle navigation"
      aria-controls="mobile-nav"
      aria-expanded="false"
    >
      {/* Icon is visible text's substitute; the button's aria-label supplies its name. */}
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  {/* Overlay stays mounted so opacity can animate; pointer-events blocks taps only when open. */}
  <div
    id="mobile-nav-overlay"
    class="fixed inset-0 z-30 bg-black/10 opacity-0 pointer-events-none transition-opacity duration-300 motion-reduce:transition-none sm:hidden"
  ></div>

  {/* Drawer starts off-canvas; the script toggles transform classes and aria-hidden. */}
  <nav
    id="mobile-nav"
    aria-label="Mobile"
    aria-hidden="true"
    class="fixed top-20 right-3 z-40 max-h-[calc(100dvh-6rem)] w-[64%] max-w-[18rem] translate-x-[120%] overflow-y-auto rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] transition-transform duration-300 ease-out motion-reduce:transition-none sm:hidden"
  >
    {/* Compact rows split by divider lines visually echo the project cards. */}
    <ul class="flex flex-col divide-y divide-[var(--color-border)]">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block px-5 py-3 text-lg no-underline',
              normalizedCurrentPath === href
                ? 'text-[var(--color-accent)]'
                : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

{/* Browser script: unlike frontmatter, this runs on the client after HTML is loaded. */}
<script>
  function setupMobileNav() {
    const toggle = document.getElementById('mobile-nav-toggle');
    const drawer = document.getElementById('mobile-nav');
    const overlay = document.getElementById('mobile-nav-overlay');

    // View Transitions can swap in fresh DOM while preserving the JS environment.
    // The dataset guard prevents duplicate listeners on the same button instance.
    if (!toggle || !drawer || !overlay || toggle.dataset.mobileNavBound === 'true') {
      return;
    }

    toggle.dataset.mobileNavBound = 'true';

    // Visual state (classes) and accessibility state (ARIA) must change together.
    function setOpen(open: boolean) {
      drawer!.classList.toggle('translate-x-[120%]', !open);
      drawer!.classList.toggle('translate-x-0', open);
      overlay!.classList.toggle('opacity-0', !open);
      overlay!.classList.toggle('pointer-events-none', !open);
      overlay!.classList.toggle('opacity-100', open);
      toggle!.setAttribute('aria-expanded', String(open));
      drawer!.setAttribute('aria-hidden', String(!open));
    }

    function isOpen() {
      return toggle!.getAttribute('aria-expanded') === 'true';
    }

    // The hamburger is both the open and close control.
    toggle.addEventListener('click', () => setOpen(!isOpen()));
    // Tapping the dimmed area closes the drawer; starting to scroll/swipe on it
    // (wheel or touch drag) also closes it so a tap-away-to-scroll gesture works.
    overlay.addEventListener('click', () => setOpen(false));
    overlay.addEventListener('wheel', () => setOpen(false), { passive: true });
    overlay.addEventListener('touchmove', () => setOpen(false), { passive: true });
    drawer.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
  }

  // Run on initial load and after every Astro View Transition navigation.
  const headerWindow = window as Window & { __mobileNavPageLoadBound?: boolean };
  if (!headerWindow.__mobileNavPageLoadBound) {
    document.addEventListener('astro:page-load', setupMobileNav);
    // Esc closes the open drawer — registered once for the page lifetime
    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      const toggle = document.getElementById('mobile-nav-toggle');
      if (toggle && toggle.getAttribute('aria-expanded') === 'true') {
        toggle.click();
      }
    });
    headerWindow.__mobileNavPageLoadBound = true;
  }
  setupMobileNav();
</script>
