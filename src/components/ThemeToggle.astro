---
/**
 * ThemeToggle.astro — Switch the site between dark and light themes.
 *
 * Base.astro sets `<html data-theme>` before paint so the first frame uses the
 * saved palette. This component is the progressive enhancement layer: it lets a
 * reader flip that attribute, stores the choice in `localStorage`, and swaps the
 * visible icon. The actual colors come from CSS tokens (`dark` by default, with
 * `[data-theme="light"]` overrides in global.css).
 *
 * Astro bundles component `<script>` tags as small browser scripts. View
 * Transition navigations can execute them again without a full page reload, so
 * the setup code below guards event binding with a window-level flag.
 */
---

{/* Icon-only button: the aria-label supplies the accessible name for screen readers. */}
<button
  id="theme-toggle"
  class="text-[var(--color-muted)] hover:text-[var(--color-text)]"
  aria-label="Toggle theme"
>
  {/* Sun icon: shown while the current theme is dark, hinting that light mode is available. */}
  {/* The path `d` attribute is SVG drawing data, not behavior controlled by this component. */}
  <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  {/* Moon icon: starts hidden; JavaScript toggles `hidden` so exactly one icon is visible. */}
  <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="hidden h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z" />
  </svg>
</button>

<script>
  /**
   * Find the current button/icons and connect the click behavior.
   *
   * This is intentionally idempotent. Astro may swap in a fresh copy of the
   * component during View Transition navigation, so the function can run many
   * times; `dataset.themeToggleBound` prevents duplicate listeners on the same
   * DOM node while still allowing newly-rendered nodes to be wired up.
   */
  function setupThemeToggle() {
    // DOM lookups happen inside setup because Astro may replace these elements between pages.
    const toggle = document.getElementById('theme-toggle');
    const sunIcon = document.getElementById('icon-sun');
    const moonIcon = document.getElementById('icon-moon');

    /**
     * Mirror `<html data-theme>` into icon visibility.
     *
     * Dark is the default: any value other than `"light"` is treated as dark so
     * missing/invalid storage gracefully falls back to the site's default theme.
     */
    function updateIcons() {
      const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
      // classList.toggle('hidden', condition) — adds 'hidden' if condition is true, removes if false
      sunIcon?.classList.toggle('hidden', !isDark);  // sun visible in dark mode
      moonIcon?.classList.toggle('hidden', isDark);  // moon visible in light mode
    }

    if (toggle && toggle.dataset.themeToggleBound !== 'true') {
      toggle.dataset.themeToggleBound = 'true';

      // When button is clicked: flip the theme, save to localStorage, update icons
      toggle.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'light' ? 'dark' : 'light';
        // setAttribute changes the data-theme on <html>, which triggers CSS color changes
        document.documentElement.setAttribute('data-theme', next);
        // localStorage persists the preference for Base.astro's pre-paint theme script.
        localStorage.setItem('theme', next);
        updateIcons();
      });
    }

    // Run on page load to set the correct icon
    updateIcons();
  }

  // Run on initial load AND after every View Transition navigation
  const themeWindow = window as Window & { __themeTogglePageLoadBound?: boolean };
  if (!themeWindow.__themeTogglePageLoadBound) {
    // astro:page-load fires after both normal loads and Astro View Transition swaps.
    document.addEventListener('astro:page-load', setupThemeToggle);
    themeWindow.__themeTogglePageLoadBound = true;
  }
  setupThemeToggle();
</script>
