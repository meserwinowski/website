---
/**
 * Dynamic project detail page — renders the full Markdown content
 * for a single project.
 *
 * The [slug] in the filename means this is a DYNAMIC ROUTE.
 * Astro generates one HTML page per project at build time:
 *   /projects/personal-website/index.html
 *   /projects/home-lab/index.html
 *   /projects/mech-keyboard/index.html
 */
import { getCollection, render } from 'astro:content';
import ProjectMeta from '../../components/ProjectMeta.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import Layout from '../../layouts/Base.astro';
import { estimateReadingTime } from '../../lib/readingTime';

// getStaticPaths() tells Astro which pages to generate at build time.
// It returns an array of { params, props } objects — one per page.
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects
    .filter((p) => ['done', 'ongoing'].includes(p.data.status))
    .map((project) => ({
      params: { slug: project.id },  // The [slug] URL parameter
      props: { project },            // Data passed to this page's template
    }));
}

// Astro.props contains the "props" from getStaticPaths for the current page
const { project } = Astro.props;

// render() converts the Markdown body into a renderable <Content /> component
// and exposes heading metadata for the project-page table of contents.
const { Content, headings } = await render(project);

const tableOfContentsHeadings = headings.filter((heading) => (
  heading.slug && heading.depth >= 1 && heading.depth <= 3
));
const showTableOfContents = tableOfContentsHeadings.length > 1;
const readingTime = estimateReadingTime(project.body);
---

<Layout title={`${project.data.title} - Matt Serwinowski`} width="wide" chrome="project-detail">
  <div class="grid gap-8 xl:items-start xl:grid-cols-[minmax(0,1fr)_minmax(0,var(--width-prose))_minmax(0,1fr)]">
    <!-- Left gutter: the sticky Table of Contents. Explicit column placement keeps
         the article centered (col 2) even when this ToC aside is absent. -->
    {showTableOfContents && (
      <aside class="hidden xl:col-start-1 xl:block">
        <div class="sticky top-8">
          <TableOfContents headings={tableOfContentsHeadings} />
        </div>
      </aside>
    )}

    <!-- <article> is semantic HTML for a self-contained piece of content (like a blog post or project) -->
    <!-- mx-auto + max-w-prose centers the reading column below xl; inside the grid it fills the center column. -->
    <article class="mx-auto w-full min-w-0 max-w-[var(--width-prose)] space-y-8 xl:col-start-2">

      <!-- Page header with back link, title, and description -->
      <header class="space-y-4">
        <!-- Back navigation link -->
        <a href="/projects/" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)] inline-block">
          ← Back to Projects
        </a>

        <h1 class="text-4xl font-bold">{project.data.title}</h1>

        <!-- Below xl there is no left rail, so the meta shows inline under the title. -->
        <div class="xl:hidden">
          <ProjectMeta
            variant="inline"
            status={project.data.status}
            tags={project.data.tags}
            date={project.data.date}
            repo={project.data.repo}
            readingMinutes={readingTime.minutes}
          />
        </div>

        <p class="text-[var(--color-muted)]">{project.data.description}</p>
      </header>

      {showTableOfContents && (
        <TableOfContents headings={tableOfContentsHeadings} variant="mobile" />
      )}

      <!-- Rendered Markdown content -->
      <!-- "prose" class applies typography styles from prose.css (headings, lists, code, tables, etc.) -->
      <!-- <Content /> is a special Astro component that renders the markdown body -->
      <div class="prose">
        <Content />
      </div>
    </article>

    <!-- Right gutter: a sticky project "spec sheet" that balances the ToC gutter and
         keeps the reading column centered (equal 1fr columns on both sides). -->
    <aside class="hidden xl:col-start-3 xl:block">
      <div class="sticky top-8">
        <ProjectMeta
          variant="rail"
          status={project.data.status}
          tags={project.data.tags}
          date={project.data.date}
          repo={project.data.repo}
          readingMinutes={readingTime.minutes}
        />
      </div>
    </aside>
  </div>
</Layout>
