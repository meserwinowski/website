---
/**
 * Projects index page — displays a grid of project cards.
 * Only shows projects with status "done" or "ongoing".
 * Sorted by date (newest first).
 */
import { getCollection } from 'astro:content';
import Layout from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

// getCollection('projects') reads all markdown files from src/content/projects/
// and parses their frontmatter into typed data objects
const allProjects = await getCollection('projects');

// Filter: only show public projects (not "planning" or "idea")
// Sort: newest date first (descending order)
const projects = allProjects
  .filter((p) => ['done', 'ongoing'].includes(p.data.status))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<!-- Layout wraps this page with the site header, footer, and <head> tags -->
<Layout title="Projects - Matt Serwinowski" width="content" chrome="project-detail" description="A curated collection of software, hardware, and music projects by Matt Serwinowski.">
  <!-- <section> groups related content together semantically -->
  <!-- space-y-6 adds 1.5rem (24px) vertical gap between children -->
  <section class="space-y-6">
    <h1 class="text-4xl font-bold">Projects</h1>

    <!-- Auto-filling grid: cards hold a ~18rem minimum and the column count grows with the -->
    <!-- viewport (1 col on mobile → more on wide screens) instead of stretching to fill. -->
    <!-- min(18rem,100%) prevents overflow on screens narrower than the card minimum. -->
    <div class="grid gap-6 grid-cols-[repeat(auto-fill,minmax(min(18rem,100%),1fr))]">
      <!-- .map() loops over the projects array and renders one ProjectCard per project -->
      <!-- Each attribute (slug, title, etc.) is a "prop" passed to the ProjectCard component -->
      {projects.map((project) => (
        <ProjectCard
          slug={project.id}
          title={project.data.title}
          description={project.data.description}
          status={project.data.status}
          tags={project.data.tags}
          thumbnail={project.data.thumbnail}
          date={project.data.date}
        />
      ))}
    </div>
  </section>
</Layout>
