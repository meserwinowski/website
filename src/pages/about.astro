---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Base.astro';

// Get the "about" page content from the pages collection (sourced from Obsidian vault)
const allPages = await getCollection('pages');
const aboutPage = allPages.find((p) => p.id === 'about');
const Content = aboutPage ? (await render(aboutPage)).Content : null;
---

<!-- About page: content managed in the Obsidian vault, synced at build time -->
<Layout title="About - Matt Serwinowski" description="About Matt Serwinowski — software engineer, builder of things.">
  <section class="space-y-8">
    <!-- Hero: hardcoded name + tagline (Brittany Chiang-inspired), distinct from the Home landing -->
    <div class="space-y-2">
      <h1 class="text-5xl font-bold tracking-tight">Matthew Serwinowski</h1>
      <p class="text-xl font-medium text-[var(--color-accent)]">Engineer / Musician</p>
    </div>

    <!-- Render markdown content from the Obsidian vault if available -->
    {Content ? (
      <div class="prose">
        <Content />
      </div>
    ) : (
      <p class="text-[var(--color-muted)] italic">Coming soon.</p>
    )}
  </section>
</Layout>
