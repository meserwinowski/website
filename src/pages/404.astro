---
/**
 * 404.astro — Static not-found route.
 *
 * Astro treats `src/pages/404.astro` specially: it is generated as the fallback
 * page for missing URLs. There is no data loading here because the route should
 * be reliable even when content collections change.
 */
import Layout from '../layouts/Base.astro';
---

<Layout title="404 - Page Not Found" description="The page you're looking for doesn't exist.">
  {/* Base.astro still supplies the shared shell, but the page body stays self-contained and dependency-free. */}
  <section class="flex flex-col items-center justify-center space-y-6 py-16 text-center">
    {/* Oversized status code gives visitors an immediate landmark before the explanatory copy. */}
    <h1 class="text-6xl font-bold text-[var(--color-muted)]">404</h1>
    <p class="text-xl text-[var(--color-text)]">Page not found</p>
    <p class="text-[var(--color-muted)]">
      The page you're looking for doesn't exist or has been moved.
    </p>
    {/* The recovery action points to `/`, the route generated by src/pages/index.astro. */}
    <a href="/" class="inline-block rounded-lg border-2 border-[var(--color-accent)] px-6 py-2 text-sm font-medium text-[var(--color-accent)] no-underline hover:bg-[var(--color-accent)] hover:text-white">
      ← Back to Home
    </a>
  </section>
</Layout>
