{
  "name": "mattserwinowski-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "node --disable-warning=DEP0205 node_modules/astro/bin/astro.mjs dev",
    "build": "node --disable-warning=DEP0205 node_modules/astro/bin/astro.mjs build",
    "preview": "node --disable-warning=DEP0205 node_modules/astro/bin/astro.mjs preview",
    "sync": "node scripts/run-local-script.mjs sync",
    "test": "npm run build && vitest run",
    "deploy": "node scripts/run-local-script.mjs deploy"
  },
  "overrides": {
    "vite": "^7"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^6.4.4",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "vitest": "^4.1.8"
  }
}
