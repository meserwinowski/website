{
  "name": "mattserwinowski-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "predev": "node scripts/generate-card-thumbnails.mjs",
    "dev": "node --disable-warning=DEP0205 node_modules/astro/bin/astro.mjs dev",
    "prebuild": "node scripts/generate-card-thumbnails.mjs",
    "build": "node --disable-warning=DEP0205 node_modules/astro/bin/astro.mjs build",
    "preview": "node --disable-warning=DEP0205 node_modules/astro/bin/astro.mjs preview --host",
    "sync": "node scripts/run-local-script.mjs sync",
    "test": "npm run build && vitest run",
    "deploy": "node scripts/run-local-script.mjs deploy",
    "spotify:token": "node scripts/spotify-refresh-token.mjs",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml"
  },
  "overrides": {
    "vite": "^7"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^6.4.4",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^24.13.1",
    "vitest": "^4.1.8",
    "wrangler": "^4.0.0"
  }
}
