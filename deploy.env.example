# Deployment configuration — copy this file to `deploy.env` and fill in your
# values. `deploy.env` is git-ignored and holds your private infrastructure
# details (host names, paths, vault location); it is never committed.

# SSH user + host of the deploy target.
# The host can be a plain hostname, an IP, or a Tailscale MagicDNS name.
NAS_USER=youruser
NAS_HOST=your-nas-host

# Absolute paths ON the remote host.
DEPLOY_TARGET=/path/to/webserver/dist
NGINX_DIR=/path/to/webserver/nginx

# Obsidian vault content folder, relative to your home directory.
# Use forward slashes on every OS (the scripts translate separators).
VAULT_SUBPATH=path/to/vault

# Optional: shared Excalidraw export folder (relative to home), if your
# drawings live outside the content folder. Leave blank to use <vault>/Excalidraw.
EXCALIDRAW_SUBPATH=

# Optional: absolute path to the `nasctl` helper used to reload nginx.
# Leave blank to discover it on PATH (recommended — keeps this file portable
# across machines). Set it only if nasctl isn't on PATH, e.g.:
#   macOS:   /Users/you/Library/CloudStorage/path/to/nasctl
#   Windows: C:\Users\you\path\to\nasctl
# This value is machine-specific; deploy.env is git-ignored and never shared.
NASCTL_PATH=

# Public URLs of the Spotify Cloudflare Worker used by the About-page widgets.
# These are NOT secrets (the Spotify credentials live in Cloudflare). They are
# exported before `npm run build` so Astro can bake them into the widgets. If
# unset, the site falls back to the committed defaults in src/config.ts.
PUBLIC_NOW_PLAYING_URL=https://api.mattserwinowski.com/now-playing
PUBLIC_LIKED_SONGS_URL=https://api.mattserwinowski.com/liked-songs
